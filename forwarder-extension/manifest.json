{
  "manifest_version": 3,
  "name": "Notification Forwarder",
  "version": "1.0.0",
  "description": "Forwards browser notifications to remote sync server",
  "permissions": [
    "notifications",
    "storage",
    "tabs",
    "webNavigation",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "ws://localhost:*/*",
    "wss://localhost:*/*",
    "https://*.ngrok.io/*",
    "https://*.ngrok-free.app/*",
    "wss://*.ngrok.io/*",
    "wss://*.ngrok-free.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-simple.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
