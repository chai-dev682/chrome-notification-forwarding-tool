# WebSocket Server Configuration
PORT=8080
AUTH_TOKEN=your-secure-token-here-change-this-in-production

# Heartbeat interval in ms (must be shorter than Cloud Run request timeout).
# Cloud Run default request timeout is 300s; max is 3600s.
HEARTBEAT_INTERVAL_MS=25000

# For production, generate a secure token:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
